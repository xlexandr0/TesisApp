{
  "expo": {
    "name": "chatbot-tesis",
    "slug": "chatbot-tesis",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Esta aplicación necesita acceso al micrófono para el reconocimiento de voz.",
        "NSSpeechRecognitionUsageDescription": "Esta aplicación necesita permiso para transcribir lo que dices."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.alexandr0.chatbottesis"
    },
    "plugins": [
      "@react-native-voice/voice"
    ]
  }
}
